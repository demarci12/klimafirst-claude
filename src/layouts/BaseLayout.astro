---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingContact from '../components/FloatingContact.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  schema?: object | object[];
  breadcrumbs?: Array<{ name: string; url: string }>;
  bodyClass?: string;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType,
  noindex,
  schema,
  breadcrumbs,
  bodyClass = '',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="hu" dir="ltr">
  <head>
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      schema={schema}
      breadcrumbs={breadcrumbs}
    />

    <!-- Inter font via Google Fonts (swap display, preconnect already in SEO) -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />

    <!-- Global styles -->
    <style is:global>
      html {
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        scroll-behavior: smooth;
        -webkit-text-size-adjust: 100%;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      main {
        flex: 1;
      }

      /* Custom scrollbar */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: #f1f5f9; }
      ::-webkit-scrollbar-thumb { background: #1e40af; border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: #1e3a8a; }

      /* Focus styles */
      :focus-visible {
        outline: 2px solid #2563eb;
        outline-offset: 2px;
        border-radius: 4px;
      }

      /* Prose styles for blog content */
      .prose-klima h2 { @apply text-2xl font-bold text-gray-900 mt-8 mb-4; }
      .prose-klima h3 { @apply text-xl font-bold text-gray-800 mt-6 mb-3; }
      .prose-klima p { @apply text-gray-700 leading-relaxed mb-4; }
      .prose-klima ul { @apply list-disc list-inside space-y-1 mb-4 text-gray-700; }
      .prose-klima ol { @apply list-decimal list-inside space-y-1 mb-4 text-gray-700; }
      .prose-klima a { @apply text-blue-700 hover:text-blue-500 underline; }
      .prose-klima strong { @apply font-semibold text-gray-900; }
      .prose-klima blockquote { @apply border-l-4 border-blue-400 pl-4 italic text-gray-600 my-4; }
      .prose-klima table { @apply w-full border-collapse text-sm; }
      .prose-klima th { @apply bg-blue-900 text-white px-4 py-2 text-left; }
      .prose-klima td { @apply border border-gray-200 px-4 py-2; }
      .prose-klima tr:nth-child(even) td { @apply bg-gray-50; }
    </style>
  </head>

  <body class={`bg-white text-gray-900 antialiased ${bodyClass}`}>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 bg-blue-900 text-white px-4 py-2 rounded-lg z-[100]">
      Ugrás a főtartalomhoz
    </a>

    <Header />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <Footer />
    <FloatingContact />
  </body>
</html>
