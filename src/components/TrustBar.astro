---
import { getSite } from '../lib/getSite';
const SITE = await getSite();

const stats = [
  {
    value: SITE.stats.references,
    label: 'Elvégzett munka',
    sublabel: 'elégedett ügyfél',
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>`,
    color: 'orange',
  },
  {
    value: `${SITE.stats.experience} év`,
    label: 'Szakmai tapasztalat',
    sublabel: 'a szakmában',
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>`,
    color: 'blue',
  },
  {
    value: SITE.stats.warranty,
    label: 'Garancia',
    sublabel: 'minden munkánkra',
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    color: 'green',
  },
  {
    value: SITE.stats.districts,
    label: 'Budapest kerület',
    sublabel: 'kiszállási díj nélkül',
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    color: 'purple',
  },
];

const colorMap: Record<string, string> = {
  orange: 'bg-orange-500/15 text-orange-300',
  blue: 'bg-blue-500/15 text-blue-300',
  green: 'bg-emerald-500/15 text-emerald-300',
  purple: 'bg-violet-500/15 text-violet-300',
};
---

<section class="bg-gradient-to-br from-blue-900 to-blue-800 text-white py-10 border-t-4 border-orange-400" aria-label="Miért válasszon minket?">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-px bg-white/10 rounded-2xl overflow-hidden">
      {stats.map((stat) => (
        <div class="bg-blue-900/60 hover:bg-blue-800/60 transition-colors duration-300 px-6 py-7 flex flex-col items-center text-center gap-3">
          <div class={`w-14 h-14 rounded-2xl flex items-center justify-center ${colorMap[stat.color]}`} set:html={stat.icon} />
          <div>
            <div class="text-3xl font-extrabold text-orange-400 tabular-nums leading-none">{stat.value}</div>
            <div class="text-sm font-semibold text-white mt-1 leading-tight">{stat.label}</div>
            <div class="text-xs text-blue-300 mt-0.5">{stat.sublabel}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
