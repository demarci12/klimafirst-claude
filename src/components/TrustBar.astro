---
import { SITE } from '../data/site';

const stats = [
  {
    value: SITE.stats.references,
    label: 'Elvégzett Referencia',
    icon: 'star',
  },
  {
    value: `${SITE.stats.experience} év`,
    label: 'Szakmai Tapasztalat',
    icon: 'calendar',
  },
  {
    value: SITE.stats.warranty,
    label: 'Garancia',
    icon: 'shield',
  },
  {
    value: SITE.stats.districts,
    label: 'Budapest Kerület',
    icon: 'map',
  },
];
---

<section class="bg-gradient-to-br from-blue-900 to-blue-800 text-white py-8 border-t-4 border-orange-400" aria-label="Statisztikák és megbízhatóság">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      {stats.map((stat) => (
        <div class="group">
          <div class="text-3xl md:text-4xl font-extrabold text-orange-400 mb-1 tabular-nums">{stat.value}</div>
          <div class="text-sm text-blue-200 tracking-wide">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
