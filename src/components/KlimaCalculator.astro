---
// Klíma Méretező Kalkulátor – Vanilla JS, no framework
---

<div class="bg-white rounded-2xl shadow-card border border-gray-100 p-6 md:p-8" id="calculator-widget">
  <div class="flex items-center gap-3 mb-6">
    <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center">
      <svg class="w-6 h-6 text-blue-800" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
    </div>
    <div>
      <h2 class="text-xl font-bold text-gray-900">Klíma Méretező Kalkulátor</h2>
      <p class="text-sm text-gray-500">Becsülje meg a szükséges teljesítményt</p>
    </div>
  </div>

  <form id="calc-form" class="space-y-5" novalidate>
    <!-- Room area -->
    <div>
      <label for="room-area" class="block text-sm font-medium text-gray-700 mb-1">
        Helyiség alapterülete (m²)
      </label>
      <div class="flex items-center gap-2">
        <input
          type="number"
          id="room-area"
          name="area"
          min="5"
          max="500"
          step="1"
          placeholder="Pl. 35"
          class="flex-1 px-4 py-2.5 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
          aria-describedby="area-hint"
        />
        <span class="text-sm text-gray-500 font-medium">m²</span>
      </div>
      <p id="area-hint" class="text-xs text-gray-400 mt-1">5 – 500 m² között adjon meg értéket</p>
    </div>

    <!-- Ceiling height -->
    <div>
      <label for="ceiling-height" class="block text-sm font-medium text-gray-700 mb-1">
        Belmagasság (m)
      </label>
      <select
        id="ceiling-height"
        name="height"
        class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors bg-white"
      >
        <option value="2.4">Standard – 2.4 m</option>
        <option value="2.7" selected>Normál – 2.7 m</option>
        <option value="3.0">Magasabb – 3.0 m</option>
        <option value="3.5">Magas – 3.5 m</option>
        <option value="4.0">Extra magas – 4.0 m+</option>
      </select>
    </div>

    <!-- Insulation quality -->
    <div>
      <label for="insulation" class="block text-sm font-medium text-gray-700 mb-1">
        Szigetelés minősége
      </label>
      <select
        id="insulation"
        name="insulation"
        class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors bg-white"
      >
        <option value="0.8">Kiváló – újépítésű, hőszigetelt</option>
        <option value="1.0" selected>Átlagos – tipikus panellakás</option>
        <option value="1.2">Gyenge – régi épület, tégla</option>
        <option value="1.4">Nagyon gyenge – szigeteletlen</option>
      </select>
    </div>

    <!-- Orientation -->
    <div>
      <label for="orientation" class="block text-sm font-medium text-gray-700 mb-1">
        Helyiség tájolása
      </label>
      <select
        id="orientation"
        name="orientation"
        class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors bg-white"
      >
        <option value="0.9">Észak / Északkelet – kevés direkt napsugárzás</option>
        <option value="1.0" selected>Kelet / Nyugat – átlagos</option>
        <option value="1.15">Dél / Délkelet / Délnyugat – erős napsugárzás</option>
      </select>
    </div>

    <!-- Occupants -->
    <div>
      <label for="occupants" class="block text-sm font-medium text-gray-700 mb-1">
        Tartózkodó személyek száma
      </label>
      <select
        id="occupants"
        name="occupants"
        class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors bg-white"
      >
        <option value="0">1 fő</option>
        <option value="1" selected>2–3 fő</option>
        <option value="2">4–5 fő</option>
        <option value="3">6+ fő</option>
      </select>
    </div>

    <button
      type="button"
      id="calc-btn"
      class="w-full bg-blue-900 hover:bg-blue-800 text-white font-semibold py-3 px-6 rounded-xl transition-all duration-300 shadow-md hover:shadow-lg text-sm"
    >
      Szükséges Teljesítmény Kiszámítása
    </button>
  </form>

  <!-- Result -->
  <div id="calc-result" class="hidden mt-6 p-5 bg-blue-50 border border-blue-200 rounded-xl" role="region" aria-live="polite" aria-label="Kalkulátor eredménye">
    <h3 class="font-bold text-blue-900 mb-3 text-lg">📊 Kalkulátor Eredménye</h3>
    <div class="grid grid-cols-2 gap-4 mb-4">
      <div class="bg-white rounded-xl p-4 text-center border border-blue-100">
        <div class="text-2xl font-bold text-blue-900" id="result-kw">–</div>
        <div class="text-xs text-gray-500 mt-1">Szükséges teljesítmény (kW)</div>
      </div>
      <div class="bg-white rounded-xl p-4 text-center border border-blue-100">
        <div class="text-2xl font-bold text-orange-600" id="result-btu">–</div>
        <div class="text-xs text-gray-500 mt-1">BTU/h egységben</div>
      </div>
    </div>
    <div id="result-recommendation" class="text-sm text-blue-800 bg-blue-100 rounded-xl p-3 mb-4"></div>
    <p class="text-xs text-gray-500 mb-3">
      <strong>Fontos:</strong> Ez egy becsült érték. A pontos méretezéshez ingyenes helyszíni felmérést ajánlunk.
    </p>
    <a
      href="/ajanlatkeres"
      class="block w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold py-3 px-4 rounded-xl text-center text-sm transition-all duration-300"
    >
      Ingyenes Helyszíni Felmérés Kérése
    </a>
  </div>

  <div id="calc-error" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700" role="alert">
    Kérem adja meg a helyiség alapterületét (5–500 m² között).
  </div>
</div>

<script>
  const calcBtn = document.getElementById('calc-btn') as HTMLButtonElement;
  const resultEl = document.getElementById('calc-result') as HTMLElement;
  const errorEl = document.getElementById('calc-error') as HTMLElement;
  const resultKw = document.getElementById('result-kw') as HTMLElement;
  const resultBtu = document.getElementById('result-btu') as HTMLElement;
  const resultRec = document.getElementById('result-recommendation') as HTMLElement;

  // Base cooling load: 50W per m³ (volume-based)
  // Adjustments for insulation, orientation, occupants
  const OCCUPANT_HEAT = [0, 100, 200, 400]; // watts per extra occupancy bracket

  function getRecommendation(kw: number): string {
    if (kw <= 2.0) return '🌬️ <strong>2.0 kW</strong> teljesítményű klíma ajánlott – kiváló kis helyiségekhez.';
    if (kw <= 2.6) return '🌬️ <strong>2.5 kW</strong> teljesítményű klíma ajánlott – tökéletes egy átlagos hálószobához.';
    if (kw <= 3.2) return '🌬️ <strong>3.2 kW</strong> teljesítményű klíma ajánlott – népszerű választás átlagos szobákhoz.';
    if (kw <= 4.0) return '🌬️ <strong>3.5–4.0 kW</strong> teljesítményű klíma ajánlott – nagy nappalihoz ideális.';
    if (kw <= 5.5) return '🌬️ <strong>5.0–5.3 kW</strong> teljesítményű klíma ajánlott – nagy, nyitott terekhez.';
    if (kw <= 7.0) return '🌬️ <strong>6.0–7.0 kW</strong> teljesítményű klíma ajánlott – irodához vagy nagy helyiséghez.';
    return '🏢 <strong>Multi-split rendszer</strong> vagy kereskedelmi klíma szükséges. Kérjen ingyenes felmérést!';
  }

  calcBtn?.addEventListener('click', () => {
    const area = parseFloat((document.getElementById('room-area') as HTMLInputElement).value);
    const height = parseFloat((document.getElementById('ceiling-height') as HTMLSelectElement).value);
    const insulation = parseFloat((document.getElementById('insulation') as HTMLSelectElement).value);
    const orientation = parseFloat((document.getElementById('orientation') as HTMLSelectElement).value);
    const occupantsIdx = parseInt((document.getElementById('occupants') as HTMLSelectElement).value);

    errorEl.classList.add('hidden');
    resultEl.classList.add('hidden');

    if (!area || area < 5 || area > 500 || isNaN(area)) {
      errorEl.classList.remove('hidden');
      return;
    }

    const volume = area * height;
    const baseWatts = volume * 50; // 50W/m³ base
    const adjustedWatts = baseWatts * insulation * orientation + OCCUPANT_HEAT[occupantsIdx];
    const kw = Math.round((adjustedWatts / 1000) * 10) / 10;
    const btu = Math.round(adjustedWatts * 3.412);

    resultKw.textContent = `${kw} kW`;
    resultBtu.textContent = `${btu.toLocaleString('hu-HU')}`;
    resultRec.innerHTML = getRecommendation(kw);

    resultEl.classList.remove('hidden');
    resultEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
