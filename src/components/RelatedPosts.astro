---
import { getCollection } from 'astro:content';
import { getBlogPosts } from '../lib/queries';

export interface Props {
  currentSlug: string;
  tags: string[];
  limit?: number;
}

const { currentSlug, tags, limit = 3 } = Astro.props;

const sanityPosts = (await getBlogPosts()) ?? [];
const mdPosts = await getCollection('tudastar');
const sanitySlugSet = new Set(sanityPosts.map((p: any) => p.slug.current));

const allPosts = [
  ...sanityPosts.map((p: any) => ({
    slug: p.slug.current,
    data: { title: p.title, description: p.description, tags: p.tags ?? [] },
  })),
  ...mdPosts
    .filter((p) => !sanitySlugSet.has(p.slug))
    .map((p) => ({ slug: p.slug, data: { title: p.data.title, description: p.data.description, tags: p.data.tags } })),
];

const related = allPosts
  .filter((post) => post.slug !== currentSlug && post.data.tags.some((tag) => tags.includes(tag)))
  .slice(0, limit);
---

{related.length > 0 && (
  <section class="py-8" aria-labelledby="related-posts-heading">
    <h3 id="related-posts-heading" class="text-xl font-bold text-gray-900 mb-4">
      Kapcsolódó Cikkek
    </h3>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {related.map((post) => (
        <article class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-4">
          <a href={`/tudastar/${post.slug}`} class="group">
            <h4 class="font-semibold text-gray-900 group-hover:text-blue-800 transition-colors text-sm leading-snug mb-2">
              {post.data.title}
            </h4>
            <p class="text-xs text-gray-500 line-clamp-2">{post.data.description}</p>
            <span class="text-xs text-blue-700 font-medium mt-2 block group-hover:text-blue-500 transition-colors">
              Cikk olvasása →
            </span>
          </a>
        </article>
      ))}
    </div>
  </section>
)}
