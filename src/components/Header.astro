---
import { SITE } from '../data/site';

const navLinks = [
  {
    label: 'Szolgáltatások',
    href: '/szolgaltatasok/klima-telepites',
    children: [
      { label: 'Klíma Telepítés', href: '/szolgaltatasok/klima-telepites' },
      { label: 'Klíma Javítás', href: '/szolgaltatasok/klima-javitas' },
      { label: 'Klíma Tisztítás', href: '/szolgaltatasok/klima-tisztitas' },
      { label: 'Fűtés Klímával', href: '/szolgaltatasok/futes-klimaval' },
    ],
  },
  { label: 'Árak', href: '/arak' },
  {
    label: 'Készülékek',
    href: '/keszulekek',
    children: [
      { label: 'Összes márka', href: '/keszulekek' },
      { label: 'Fisher Klíma', href: '/keszulekek/fisher-klima' },
      { label: 'Fujitsu Klíma', href: '/keszulekek/fujitsu-klima' },
      { label: 'Toshiba Klíma', href: '/keszulekek/toshiba-klima' },
    ],
  },
  { label: 'Referenciák', href: '/referenciak' },
  { label: 'Tudástár', href: '/tudastar' },
  { label: 'Rólunk', href: '/rolunk' },
];

const currentPath = Astro.url.pathname;
---

<header class="w-full bg-white shadow-sm sticky top-0 z-50" id="site-header">
  <!-- Top bar -->
  <div class="bg-blue-900 text-white text-sm py-1.5">
    <div class="container mx-auto px-4 flex justify-between items-center">
      <span class="hidden sm:block text-blue-200">Budapest mind a 23 kerületében – kiszállási díj nélkül</span>
      <a
        href={`tel:${SITE.phoneTel}`}
        class="font-bold text-orange-400 hover:text-orange-300 transition-colors flex items-center gap-1"
        aria-label={`Hívjon minket: ${SITE.phone}`}
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
        </svg>
        {SITE.phone}
      </a>
    </div>
  </div>

  <!-- Main nav -->
  <nav class="container mx-auto px-4 py-3 flex items-center justify-between" aria-label="Főnavigáció">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group" aria-label="KlimaFirst – Főoldal">
      <div class="w-10 h-10 bg-blue-900 rounded-xl flex items-center justify-center shadow-md group-hover:bg-blue-800 transition-colors">
        <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
        </svg>
      </div>
      <div>
        <span class="text-xl font-bold text-blue-900 leading-none">KlimaFirst</span>
        <span class="text-xs text-gray-500 block leading-none">{SITE.tagline}</span>
      </div>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-1" role="list">
      {navLinks.map((link) => (
        <li class="relative group" role="listitem">
          {link.children ? (
            <>
              <button
                class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors flex items-center gap-1 ${
                  currentPath.startsWith(link.href)
                    ? 'text-blue-900 bg-blue-50'
                    : 'text-gray-700 hover:text-blue-900 hover:bg-gray-50'
                }`}
                aria-expanded="false"
                aria-haspopup="true"
              >
                {link.label}
                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <ul
                class="absolute top-full left-0 mt-1 w-52 bg-white rounded-xl shadow-lg border border-gray-100 py-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
                role="menu"
              >
                {link.children.map((child) => (
                  <li role="menuitem">
                    <a
                      href={child.href}
                      class={`block px-4 py-2.5 text-sm transition-colors ${
                        currentPath === child.href
                          ? 'text-blue-900 bg-blue-50 font-medium'
                          : 'text-gray-700 hover:text-blue-900 hover:bg-gray-50'
                      }`}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </>
          ) : (
            <a
              href={link.href}
              class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
                currentPath === link.href
                  ? 'text-blue-900 bg-blue-50'
                  : 'text-gray-700 hover:text-blue-900 hover:bg-gray-50'
              }`}
            >
              {link.label}
            </a>
          )}
        </li>
      ))}
    </ul>

    <!-- CTA Buttons -->
    <div class="hidden lg:flex items-center gap-2">
      <a
        href="/ajanlatkeres"
        class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded-xl text-sm font-semibold transition-all duration-300 shadow-md hover:shadow-lg"
      >
        Ingyenes Árajánlat
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden p-2 rounded-lg text-gray-700 hover:bg-gray-100 transition-colors"
      aria-label="Menü megnyitása"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="hamburger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-gray-100 bg-white"
    role="navigation"
    aria-label="Mobil navigáció"
  >
    <ul class="container mx-auto px-4 py-3 space-y-1" role="list">
      {navLinks.map((link) => (
        <li role="listitem">
          {link.children ? (
            <details class="group">
              <summary class="flex items-center justify-between px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 cursor-pointer list-none">
                {link.label}
                <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <ul class="mt-1 ml-3 space-y-1" role="list">
                {link.children.map((child) => (
                  <li role="menuitem">
                    <a
                      href={child.href}
                      class="block px-3 py-2 rounded-lg text-sm text-gray-600 hover:text-blue-900 hover:bg-blue-50 transition-colors"
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ) : (
            <a
              href={link.href}
              class={`block px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${
                currentPath === link.href
                  ? 'text-blue-900 bg-blue-50'
                  : 'text-gray-700 hover:text-blue-900 hover:bg-gray-50'
              }`}
            >
              {link.label}
            </a>
          )}
        </li>
      ))}
      <li class="pt-2 border-t border-gray-100">
        <a
          href="/ajanlatkeres"
          class="block w-full bg-orange-500 hover:bg-orange-600 text-white px-4 py-3 rounded-xl text-sm font-semibold text-center transition-colors"
        >
          Ingyenes Árajánlat kérése
        </a>
      </li>
      <li>
        <a
          href={`tel:${SITE.phoneTel}`}
          class="block w-full border border-blue-900 text-blue-900 px-4 py-3 rounded-xl text-sm font-semibold text-center transition-colors hover:bg-blue-50"
        >
          📞 {SITE.phone}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    hamburger?.classList.toggle('hidden', isOpen === false);
    closeIcon?.classList.toggle('hidden', isOpen === true);
    btn?.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu on outside click
  document.addEventListener('click', (e) => {
    if (!btn?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      menu?.classList.add('hidden');
      hamburger?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
