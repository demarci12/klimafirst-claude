---
import { getSite } from '../lib/getSite';
const SITE = await getSite();

const currentYear = new Date().getFullYear();

const footerServices = [
  { label: 'Klíma Telepítés', href: '/szolgaltatasok/klima-telepites' },
  { label: 'Klíma Javítás', href: '/szolgaltatasok/klima-javitas' },
  { label: 'Klíma Tisztítás', href: '/szolgaltatasok/klima-tisztitas' },
  { label: 'Fűtés Klímával', href: '/szolgaltatasok/futes-klimaval' },
  { label: 'Árainkat', href: '/arak' },
];

const footerBrands = [
  { label: 'Fisher Klíma', href: '/keszulekek/fisher-klima' },
  { label: 'Fujitsu Klíma', href: '/keszulekek/fujitsu-klima' },
  { label: 'Toshiba Klíma', href: '/keszulekek/toshiba-klima' },
  { label: 'Összes készülék', href: '/keszulekek' },
];

const footerCompany = [
  { label: 'Rólunk', href: '/rolunk' },
  { label: 'Referenciák', href: '/referenciak' },
  { label: 'Tudástár', href: '/tudastar' },
  { label: 'Kapcsolat', href: '/kapcsolat' },
  { label: 'Árajánlatkérés', href: '/ajanlatkeres' },
  { label: 'Klíma Kalkulátor', href: '/klima-meretezo-kalkulator' },
];
---

<footer class="bg-gray-900 text-gray-300" aria-label="Oldal lábléce">
  <div class="container mx-auto px-4 pt-16 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Company column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-5 group" aria-label="Klímaépítő.hu főoldal">
          <div class="relative w-11 h-11 flex-shrink-0">
            <div class="absolute inset-0 rounded-xl bg-gradient-to-br from-blue-600 to-blue-800"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
              </svg>
            </div>
            <span class="absolute -top-0.5 -right-0.5 w-2.5 h-2.5 bg-orange-500 rounded-full border-2 border-gray-900"></span>
          </div>
          <div>
            <div class="text-lg font-extrabold text-white tracking-tight leading-none">Klímaépítő<span class="text-orange-500">.hu</span></div>
            <div class="text-[10px] text-gray-400 uppercase tracking-widest mt-0.5">{SITE.tagline}</div>
          </div>
        </a>

        <p class="text-sm text-gray-400 mb-6 leading-relaxed">
          Professzionális klímaszerelés, javítás és karbantartás Budapesten és környékén. Több száz elégedett ügyfél, gyors kiszállás, ingyenes felmérés.
        </p>

        <address class="not-italic space-y-3">
          <a href={`tel:${SITE.phoneTel}`} class="flex items-center gap-3 group/phone" aria-label={`Telefonszám: ${SITE.phone}`}>
            <div class="w-8 h-8 rounded-lg bg-orange-500/10 flex items-center justify-center flex-shrink-0 group-hover/phone:bg-orange-500/20 transition-colors">
              <svg class="w-4 h-4 text-orange-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
              </svg>
            </div>
            <span class="text-sm font-bold text-orange-400 hover:text-orange-300 transition-colors">{SITE.phone}</span>
          </a>
          <a href={`mailto:${SITE.email}`} class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-blue-500/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <span class="text-sm text-gray-400 hover:text-white transition-colors">{SITE.email}</span>
          </a>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-slate-700/50 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <span class="text-sm text-gray-400">Budapest, Magyarország</span>
          </div>
        </address>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">
          <span class="w-4 h-0.5 bg-orange-500 inline-block rounded-full"></span>
          Szolgáltatások
        </h3>
        <ul class="space-y-2.5" role="list">
          {footerServices.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-orange-400 transition-colors flex items-center gap-2 group/link">
                <span class="w-1 h-1 rounded-full bg-slate-600 group-hover/link:bg-orange-400 transition-colors flex-shrink-0"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Brands -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">
          <span class="w-4 h-0.5 bg-orange-500 inline-block rounded-full"></span>
          Klíma Márkák
        </h3>
        <ul class="space-y-2.5 mb-8" role="list">
          {footerBrands.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-orange-400 transition-colors flex items-center gap-2 group/link">
                <span class="w-1 h-1 rounded-full bg-slate-600 group-hover/link:bg-orange-400 transition-colors flex-shrink-0"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">
          <span class="w-4 h-0.5 bg-blue-500 inline-block rounded-full"></span>
          Eszközök
        </h3>
        <ul class="space-y-2.5" role="list">
          <li>
            <a href="/klima-meretezo-kalkulator" class="text-sm text-gray-400 hover:text-orange-400 transition-colors flex items-center gap-2 group/link">
              <span class="w-1 h-1 rounded-full bg-slate-600 group-hover/link:bg-blue-400 transition-colors flex-shrink-0"></span>
              Klíma Méretező
            </a>
          </li>
          <li>
            <a href="/ajanlatkeres" class="text-sm text-gray-400 hover:text-orange-400 transition-colors flex items-center gap-2 group/link">
              <span class="w-1 h-1 rounded-full bg-slate-600 group-hover/link:bg-blue-400 transition-colors flex-shrink-0"></span>
              Online Árajánlat
            </a>
          </li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">
          <span class="w-4 h-0.5 bg-orange-500 inline-block rounded-full"></span>
          Cégünk
        </h3>
        <ul class="space-y-2.5 mb-6" role="list">
          {footerCompany.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-orange-400 transition-colors flex items-center gap-2 group/link">
                <span class="w-1 h-1 rounded-full bg-slate-600 group-hover/link:bg-orange-400 transition-colors flex-shrink-0"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <div class="rounded-2xl bg-gradient-to-br from-blue-600/20 to-blue-800/20 border border-blue-700/30 p-4">
          <p class="text-xs font-semibold text-blue-300 mb-1">Ingyenes helyszíni felmérés</p>
          <p class="text-xs text-slate-500 mb-3">Kiszállási díj nélkül. 24 órán belül visszahívjuk.</p>
          <a href="/ajanlatkeres" class="block text-center text-xs font-bold text-white bg-orange-500 hover:bg-orange-600 transition-colors px-3 py-2 rounded-lg">
            Árajánlatot kérek →
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-white/5">
    <div class="container mx-auto px-4 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-500">
      <p>© {currentYear} <span class="text-gray-400">{SITE.legalName}</span> – Minden jog fenntartva.</p>
      <div class="flex items-center gap-5">
        <a href="/kapcsolat" class="hover:text-slate-300 transition-colors">Kapcsolat</a>
        <a href="/rolunk" class="hover:text-slate-300 transition-colors">Rólunk</a>
        <a href="/tudastar" class="hover:text-slate-300 transition-colors">Tudástár</a>
        <a href="/arak" class="hover:text-slate-300 transition-colors">Árak</a>
      </div>
    </div>
  </div>
</footer>
