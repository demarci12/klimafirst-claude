---
import { SITE } from '../data/site';

const currentYear = new Date().getFullYear();

const footerServices = [
  { label: 'Klíma Telepítés és Értékesítés', href: '/szolgaltatasok/klima-telepites' },
  { label: 'Klíma Javítás Budapest', href: '/szolgaltatasok/klima-javitas' },
  { label: 'Klíma Tisztítás és Karbantartás', href: '/szolgaltatasok/klima-tisztitas' },
  { label: 'Fűtés Klímával', href: '/szolgaltatasok/futes-klimaval' },
  { label: 'Klímaszerelés Árak 2025', href: '/arak' },
];

const footerBrands = [
  { label: 'Fisher Klíma Budapest', href: '/keszulekek/fisher-klima' },
  { label: 'Fujitsu Klíma Budapest', href: '/keszulekek/fujitsu-klima' },
  { label: 'Toshiba Klíma Budapest', href: '/keszulekek/toshiba-klima' },
  { label: 'Összes Klímakészülék', href: '/keszulekek' },
];

const footerCompany = [
  { label: 'Rólunk – KlimaFirst', href: '/rolunk' },
  { label: 'Referenciák', href: '/referenciak' },
  { label: 'Tudástár – Klíma Blog', href: '/tudastar' },
  { label: 'Kapcsolat', href: '/kapcsolat' },
  { label: 'Ingyenes Árajánlat', href: '/ajanlatkeres' },
  { label: 'Klíma Méretező Kalkulátor', href: '/klima-meretezo-kalkulator' },
];
---

<footer class="bg-gray-900 text-gray-300">
  <!-- Main footer -->
  <div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Company info / NAP -->
      <div class="lg:col-span-1">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 mb-4 group" aria-label="KlimaFirst főoldal">
          <div class="w-10 h-10 bg-blue-800 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <div>
            <span class="text-xl font-bold text-white">KlimaFirst</span>
            <span class="text-xs text-gray-400 block">{SITE.tagline}</span>
          </div>
        </a>

        <p class="text-sm text-gray-400 mb-4 leading-relaxed">
          Professzionális klímaszerelés, javítás és karbantartás Budapesten – 5000+ elégedett ügyfél, gyors kiszállás, ingyenes helyszíni felmérés.
        </p>

        <!-- NAP in address tag for SEO -->
        <address class="not-italic text-sm space-y-2">
          <div class="flex items-start gap-2">
            <svg class="w-4 h-4 text-orange-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>
              <strong class="text-white">{SITE.legalName}</strong><br />
              Budapest, Magyarország
            </span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-orange-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${SITE.phoneTel}`} class="text-orange-400 hover:text-orange-300 font-semibold transition-colors">
              {SITE.phone}
            </a>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-orange-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${SITE.email}`} class="hover:text-white transition-colors">
              {SITE.email}
            </a>
          </div>
        </address>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Szolgáltatások</h3>
        <ul class="space-y-2" role="list">
          {footerServices.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-orange-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Brands -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Klíma Márkák</h3>
        <ul class="space-y-2" role="list">
          {footerBrands.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-orange-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <h3 class="text-white font-semibold mt-6 mb-4 text-sm uppercase tracking-wider">Hasznos Eszközök</h3>
        <ul class="space-y-2" role="list">
          <li>
            <a href="/klima-meretezo-kalkulator" class="text-sm text-gray-400 hover:text-orange-400 transition-colors">
              Klíma Méretező Kalkulátor
            </a>
          </li>
          <li>
            <a href="/ajanlatkeres" class="text-sm text-gray-400 hover:text-orange-400 transition-colors">
              Online Árajánlatkérő
            </a>
          </li>
        </ul>
      </div>

      <!-- Company links -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Cégünk</h3>
        <ul class="space-y-2 mb-6" role="list">
          {footerCompany.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-orange-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Service area highlight -->
        <div class="bg-blue-900/50 rounded-xl p-3">
          <p class="text-xs text-blue-300 font-medium mb-1">Ellátott területek</p>
          <p class="text-xs text-gray-400">Budapest mind a 23 kerülete + Budapest–Siófok korridor</p>
          <a href="/budapest/i-kerulet" class="text-xs text-orange-400 hover:text-orange-300 transition-colors mt-1 block">
            Összes kerület megtekintése →
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-800">
    <div class="container mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-500">
      <p>© {currentYear} {SITE.legalName} – Minden jog fenntartva.</p>
      <div class="flex items-center gap-4">
        <a href="/kapcsolat" class="hover:text-gray-300 transition-colors">Kapcsolat</a>
        <span>|</span>
        <a href="/rolunk" class="hover:text-gray-300 transition-colors">Rólunk</a>
        <span>|</span>
        <a href="/tudastar" class="hover:text-gray-300 transition-colors">Tudástár</a>
      </div>
    </div>
  </div>
</footer>
