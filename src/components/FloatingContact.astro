---
import { getSite } from '../lib/getSite';
const SITE = await getSite();
---

<!-- Floating CTA for mobile -->
<div class="fixed bottom-4 right-4 z-50 flex flex-col gap-2 md:hidden" aria-label="Gyors kapcsolatfelvétel">
  <a
    href={`tel:${SITE.phoneTel}`}
    class="w-14 h-14 bg-orange-500 hover:bg-orange-600 text-white rounded-full shadow-lg hover:shadow-xl flex items-center justify-center transition-all duration-300 hover:scale-110"
    aria-label={`Hívjon most: ${SITE.phone}`}
  >
    <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
      <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
    </svg>
  </a>
</div>

<!-- Desktop bottom bar CTA (hidden on mobile since we have floating btn) -->
<div
  class="hidden md:block fixed bottom-0 left-0 right-0 z-40 bg-blue-900 text-white py-3 shadow-2xl"
  id="sticky-cta-bar"
  aria-label="Gyors elérhetőség"
>
  <div class="container mx-auto px-4 flex items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <svg class="w-5 h-5 text-orange-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
      </svg>
      <span class="text-sm">Ingyenes helyszíni felmérés Budapesten – hívjon most!</span>
    </div>
    <div class="flex items-center gap-3">
      <a
        href={`tel:${SITE.phoneTel}`}
        class="bg-orange-500 hover:bg-orange-600 text-white px-5 py-2 rounded-xl font-semibold text-sm transition-colors whitespace-nowrap"
      >
        {SITE.phone}
      </a>
      <button
        id="close-sticky-bar"
        class="text-blue-300 hover:text-white transition-colors"
        aria-label="Bezárás"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>
</div>

<script>
  const closeBtn = document.getElementById('close-sticky-bar');
  const stickyBar = document.getElementById('sticky-cta-bar');

  closeBtn?.addEventListener('click', () => {
    stickyBar?.classList.add('hidden');
  });

  // Show bar after 3 seconds scroll
  let shown = false;
  window.addEventListener('scroll', () => {
    if (!shown && window.scrollY > 400) {
      stickyBar?.classList.remove('hidden');
      stickyBar?.classList.add('animate-fade-in');
      shown = true;
    }
  });

  // Initially hide the bar
  if (stickyBar) {
    stickyBar.style.display = 'none';
  }
</script>
