---
export interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
  highlight?: boolean;
  price?: string;
}

const { title, description, href, icon, highlight = false, price } = Astro.props;
---

<article
  class={`rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 group flex flex-col ${
    highlight
      ? 'bg-blue-900 text-white shadow-lg shadow-blue-900/30'
      : 'bg-white border border-gray-100 shadow-card hover:shadow-card-hover'
  }`}
>
  {icon && (
    <div
      class={`w-12 h-12 rounded-xl flex items-center justify-center mb-4 transition-colors ${
        highlight ? 'bg-blue-800' : 'bg-blue-50 group-hover:bg-blue-100'
      }`}
    >
      <span class="text-2xl" aria-hidden="true">{icon}</span>
    </div>
  )}

  <h3
    class={`text-lg font-bold mb-2 ${highlight ? 'text-white' : 'text-gray-900'}`}
  >
    {title}
  </h3>

  <p class={`text-sm leading-relaxed flex-grow ${highlight ? 'text-blue-200' : 'text-gray-600'}`}>
    {description}
  </p>

  {price && (
    <div class={`mt-3 text-sm font-semibold ${highlight ? 'text-orange-400' : 'text-blue-800'}`}>
      {price}
    </div>
  )}

  <a
    href={href}
    class={`mt-4 inline-flex items-center gap-1 text-sm font-semibold transition-colors ${
      highlight
        ? 'text-orange-400 hover:text-orange-300'
        : 'text-blue-800 hover:text-blue-600'
    }`}
    aria-label={`Részletek: ${title}`}
  >
    Részletek megtekintése
    <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </a>
</article>
