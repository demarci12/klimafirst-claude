---
export interface FAQItem {
  question: string;
  answer: string;
}

export interface Props {
  items: FAQItem[];
  title?: string;
  includeSchema?: boolean;
}

const { items, title = 'Gyakran Ismételt Kérdések', includeSchema = true } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

{includeSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}

<section class="py-12" aria-labelledby="faq-heading">
  <div class="container mx-auto px-4 max-w-3xl">
    <h2 id="faq-heading" class="text-2xl md:text-3xl font-bold text-gray-900 text-center mb-8">
      {title}
    </h2>

    <div class="space-y-3">
      {items.map((item, index) => (
        <details
          class="group bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow"
          id={`faq-${index}`}
        >
          <summary class="flex items-center justify-between p-5 cursor-pointer list-none font-semibold text-gray-900 hover:text-blue-900 transition-colors gap-3">
            <span>{item.question}</span>
            <svg
              class="w-5 h-5 flex-shrink-0 text-blue-800 transition-transform duration-300 group-open:rotate-180"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-5 pb-5 text-gray-600 text-sm leading-relaxed border-t border-gray-100 pt-4">
            <Fragment set:html={item.answer} />
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
