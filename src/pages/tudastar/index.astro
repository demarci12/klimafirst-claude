---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getBlogPosts } from '../../lib/queries';

// Merge Sanity posts + MD fallback posts
const sanityPosts = (await getBlogPosts()) ?? [];
const mdPosts = await getCollection('tudastar');

// Normalize to common shape
const normalizedSanity = sanityPosts.map((p: any) => ({
  slug: p.slug.current,
  data: { title: p.title, description: p.description, pubDate: new Date(p.pubDate), tags: p.tags ?? [], author: p.author ?? 'Juhász Balázs' },
  _source: 'sanity',
}));
const sanitySlugSet = new Set(normalizedSanity.map((p: any) => p.slug));
const normalizedMd = mdPosts
  .filter((p) => !sanitySlugSet.has(p.slug))
  .map((p) => ({ ...p, _source: 'md' }));

const allPosts = [...normalizedSanity, ...normalizedMd];
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Tudástár – Klímaszerelés, Karbantartás és Energiatakarékosság | Klímaépítő.hu"
  description="Szakértői cikkek klímaszerelésről, karbantartásról, energiatakarékosságról és klíma tippekről. Klímaépítő.hu tudástár – ingyenes útmutatók."
  canonical="/tudastar"
  breadcrumbs={[{ name: 'Tudástár', url: '/tudastar' }]}
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4">
      <Breadcrumb items={[{ name: 'Tudástár', href: '/tudastar' }]} />
    </div>
  </div>

  <section class="bg-gradient-to-br from-blue-900 to-blue-800 text-white py-12">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-3">Tudástár – Klíma Blog</h1>
      <p class="text-blue-100 text-lg max-w-2xl mx-auto">
        Szakértői útmutatók, tippek és aktuális információk klímaszerelésről, karbantartásról és energiatakarékos otthonról.
      </p>
    </div>
  </section>

  <section class="py-10 bg-white">
    <div class="container mx-auto px-4 max-w-5xl">
      <!-- Tag filter -->
      <div class="flex flex-wrap gap-2 mb-8">
        <span class="text-sm font-medium text-gray-600 mr-2 self-center">Témák:</span>
        {allTags.map((tag) => (
          <span class="bg-blue-50 text-blue-700 px-3 py-1 rounded-full text-xs font-medium border border-blue-100">
            {tag}
          </span>
        ))}
      </div>

      <!-- Post grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedPosts.map((post) => (
          <article class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-0.5 overflow-hidden group flex flex-col">
            <div class="p-5 flex flex-col flex-grow">
              <div class="flex flex-wrap gap-1 mb-3">
                {post.data.tags.slice(0, 2).map((tag: string) => (
                  <span class="text-xs bg-blue-50 text-blue-700 px-2 py-0.5 rounded-full">{tag}</span>
                ))}
              </div>

              <h2 class="font-bold text-gray-900 group-hover:text-blue-800 transition-colors mb-2 leading-snug flex-grow">
                <a href={`/tudastar/${post.slug}`}>{post.data.title}</a>
              </h2>

              <p class="text-sm text-gray-600 line-clamp-2 mb-4">{post.data.description}</p>

              <div class="flex items-center justify-between text-xs text-gray-400 mt-auto">
                <span class="flex items-center gap-1">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                  </svg>
                  {post.data.author}
                </span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('hu-HU', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>
            </div>

            <div class="px-5 pb-4">
              <a
                href={`/tudastar/${post.slug}`}
                class="block w-full text-center text-sm font-semibold text-blue-800 hover:text-blue-600 py-2 border border-blue-200 rounded-xl hover:bg-blue-50 transition-colors"
              >
                Cikk olvasása →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
