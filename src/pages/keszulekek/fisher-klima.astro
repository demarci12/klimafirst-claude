---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import QuizForm from '../../components/QuizForm.astro';
import { SITE } from '../../data/site';
import { getBrandPage } from '../../lib/queries';

const brandData = await getBrandPage('fisher-klima');
const faqs = brandData?.faqs ?? [
  { question: 'Milyen garancia jár a Fisher klímára?', answer: 'A Fisher klímaberendezések általában 2 év gyártói garanciával érkeznek. A Klímaépítő.hu által elvégzett telepítési munkára külön 2 év munkadíj garanciát vállalunk.' },
  { question: 'Mennyibe kerül egy Fisher klíma telepítéssel együtt?', answer: 'Egy Fisher 2.5 kW-os klíma telepítéssel együtt kb. 165.000–185.000 Ft közé esik. Pontos ár ingyenes helyszíni felméréssel állapítható meg.' },
  { question: 'Tud-e a Fisher klíma fűteni is?', answer: 'Igen, a Fisher inverteres klímaberendezések hőszivattyúként is működnek, és -15°C-ig hatékonyan fűtenek.' },
];
---

<BaseLayout
  title="Fisher Klíma Budapest – Telepítés, Értékesítés, Szerviz | Klímaépítő.hu"
  description="Fisher klíma telepítés és értékesítés Budapesten. Kiváló ár-érték arány, 2 év garancia, ingyenes helyszíni felmérés. ☎ +36 20 339 4164"
  canonical="/keszulekek/fisher-klima"
  breadcrumbs={[{ name: 'Klímakészülékek', url: '/keszulekek' }, { name: 'Fisher Klíma', url: '/keszulekek/fisher-klima' }]}
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4">
      <Breadcrumb items={[{ name: 'Klímakészülékek', href: '/keszulekek' }, { name: 'Fisher Klíma', href: '/keszulekek/fisher-klima' }]} />
    </div>
  </div>

  <section class="bg-gradient-to-br from-blue-900 to-blue-800 text-white py-14">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-4">Fisher Klíma Budapest</h1>
      <p class="text-lg text-blue-100 mb-6 max-w-2xl mx-auto">
        Fisher klímakészülékek értékesítése és telepítése Budapesten. Kiváló ár-érték arány, megbízható minőség, ingyenes helyszíni felmérés.
      </p>
      <a href="/ajanlatkeres" class="bg-orange-500 hover:bg-orange-600 text-white px-6 py-3 rounded-xl font-bold transition-colors inline-block">
        Fisher Klíma Árajánlat
      </a>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="prose-klima">
        <h2>Miért Válasszon Fisher Klímát?</h2>
        <p>A Fisher klíma a legjobb ár-érték arányú márkák egyike a piacon. Kiváló hűtési és fűtési teljesítmény, modern inverteres technológia, és megbízható minőség – mindezt versenyképes áron.</p>

        <h2>Fisher Klíma Modellek</h2>
        <ul>
          <li><strong>Fisher FSSB-09AE3 (2.5 kW):</strong> Ideális 15–25 m² szobához. Ár: ~130.000 Ft</li>
          <li><strong>Fisher FSSB-12AE3 (3.5 kW):</strong> Optimális 25–40 m² helyiséghez. Ár: ~155.000 Ft</li>
          <li><strong>Fisher FSSB-18AE3 (5.0 kW):</strong> Nagy terekhez, 40–65 m². Ár: ~200.000 Ft</li>
        </ul>

        <h2>Fisher Klíma Főbb Jellemzői</h2>
        <ul>
          <li>Inverteres kompresszor – 30–50% energiamegtakarítás</li>
          <li>A++ – A+++ energiaosztály</li>
          <li>Éjszakai csendes mód (22 dB)</li>
          <li>Önkikapcsoló és önindulási funkciók</li>
          <li>R32 hűtőközeg – környezetbarátabb</li>
          <li>Hőmérő funkcióval ellátott távirányító</li>
        </ul>

        <h2>Telepítés és Garancia</h2>
        <p>A Klímaépítő.hu csapata elvégzi a Fisher klíma helyszíni felmérését, telepítését és beüzemelését. Az elvégzett munkára <strong>2 év garanciát</strong> vállalunk. A készülékre a gyártói garancia érvényes.</p>
      </div>
    </div>
  </section>

  <FAQ items={faqs} title="Fisher Klíma – Leggyakoribb Kérdések" />

  <section class="py-12 bg-gray-50">
    <div class="container mx-auto px-4 max-w-xl">
      <QuizForm title="Fisher Klíma Árajánlat Kérése" />
    </div>
  </section>
</BaseLayout>
