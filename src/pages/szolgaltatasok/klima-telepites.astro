---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import PriceTable from '../../components/PriceTable.astro';
import QuizForm from '../../components/QuizForm.astro';
import TrustBar from '../../components/TrustBar.astro';
import { getSite } from '../../lib/getSite';
const SITE = await getSite();

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const serviceData = null;

const heroTitle = serviceData?.title ?? 'Klíma Telepítés és Értékesítés Budapest';
const heroSubtitle = serviceData?.subtitle ?? 'Fisher, Fujitsu, Toshiba és Daikin split és multi-split klímarendszerek professzionális telepítése. Ingyenes helyszíni felmérés, kiszállási díj nélkül mind a 23 kerületben.';
const heroIcon = serviceData?.heroIcon ?? '❄️';
const photo1Src = serviceData?.photo1?.src ?? '/images/juhasz-balazs/jb-gree-beszereles-letran-1.jpeg';
const photo1Alt = serviceData?.photo1?.alt ?? 'Juhász Balázs Gree kültéri klíma beszerelése létráról – Klímaépítő.hu Budapest klímaszerelő';
const photo2Src = serviceData?.photo2?.src ?? '/images/juhasz-balazs/jb-gree-egyseg-vallon-1.jpeg';
const photo2Alt = serviceData?.photo2?.alt ?? 'Juhász Balázs telepített Gree kültéri klíma egységgel – Klímaépítő.hu Budapest';
const photoLabel = serviceData?.photoSectionLabel ?? 'Tulajdonos-szerelő';
const photoTitle = serviceData?.photoSectionTitle ?? 'Juhász Balázs személyesen végzi a telepítést';
const photoText = serviceData?.photoSectionText ?? '10+ év tapasztalat, 5000+ elvégzett klíma telepítés Budapesten. Minden munkára 2 év garanciát vállalunk.';
const bodyHtml = serviceData?.body ? toHTML(serviceData.body) : null;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: heroTitle,
  description: heroSubtitle,
  provider: { '@type': 'HVACBusiness', name: 'Klímaépítő.hu', telephone: SITE.phoneTel, url: `${siteUrl}/` },
  areaServed: { '@type': 'City', name: 'Budapest' },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Klíma Telepítés Árak',
    itemListElement: [{ '@type': 'Offer', name: 'Split klíma telepítés (2.5 kW)', priceSpecification: { '@type': 'PriceSpecification', minPrice: 35000, priceCurrency: 'HUF' } }],
  },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '98', bestRating: '5' },
};

const priceItems = serviceData?.priceItems ?? [
  { service: 'Split klíma telepítés (2.5 kW)', description: 'Beltéri + kültéri egység, szokásos falvastagság', price: '35.000', note: 'Munkadíj' },
  { service: 'Split klíma telepítés (3.5 kW)', description: 'Beltéri + kültéri egység, szokásos falvastagság', price: '38.000', note: 'Munkadíj' },
  { service: 'Split klíma telepítés (5.0 kW+)', description: 'Nagy teljesítményű egységek, irodai felhasználás', price: '45.000', note: 'Munkadíj' },
  { service: 'Multi-split 2 beltéri egység', description: '1 kültéri + 2 beltéri egység telepítése', price: '65.000', note: 'Munkadíj' },
  { service: 'Multi-split 3 beltéri egység', description: '1 kültéri + 3 beltéri egység telepítése', price: '85.000', note: 'Munkadíj' },
  { service: 'Rézcső hosszabbítás (méterenkénti)', description: 'Standard 3/8" + 1/4" rézcső pár', price: '3.500', note: '/fm' },
  { service: 'Klíma készülék ár (2.5–3.5 kW)', description: 'Fisher, Fujitsu vagy Toshiba split klíma', price: '130.000', highlight: true, note: 'Készülékár' },
];

const faqs = serviceData?.faqs ?? [
  { question: 'Mennyi idő alatt szerelik fel a klímát?', answer: 'Egy split klíma telepítése általában 3–6 óra alatt elvégezhető. Multi-split rendszereknél ez 1–2 napot vehet igénybe, a beltéri egységek számától függően.' },
  { question: 'Hol helyezik el a kültéri egységet?', answer: 'A kültéri egységet általában az erkélyen, homlokzaton, tetőn vagy az épület oldalán helyezzük el. Minden esetben figyelünk a szabályos elhelyezésre, a megfelelő áramlásra és a zaj minimalizálására.' },
  { question: 'Kell-e engedély a klíma telepítéséhez?', answer: 'Önálló lakóháznál általában nem kell engedély. Társasházi lakásoknál a kültéri egység elhelyezéséhez esetenként a közös képviselő vagy az önkormányzat engedélye szükséges – erről a helyszíni felmérésnél tájékoztatjuk.' },
  { question: 'Milyen típusú klímákat szerelnek?', answer: 'Split, multi-split és kazettás klímarendszereket szerelünk. Forgalmazott márkák: Fisher, Fujitsu, Toshiba, Daikin. Más márkák szervizét is elvégezzük.' },
  { question: 'Mi az ingyenes helyszíni felmérés menete?', answer: 'Szerelőink kiszállnak (kiszállási díj nélkül), felmérjük a helyiséget és az épületet, meghatározzuk a szükséges teljesítményt, javaslatot teszünk a telepítési helyre, majd írásos, tételes árajánlatot küldünk.' },
];
---

<BaseLayout
  title="Klíma Telepítés Budapest – Split és Multi-Split Rendszerek | Klímaépítő.hu"
  description="Professzionális klíma telepítés Budapesten. Fisher, Fujitsu, Toshiba, Daikin klímarendszerek. Ingyenes helyszíni felmérés, kiszállási díj nélkül. ☎ +36 20 339 4164"
  canonical="/szolgaltatasok/klima-telepites"
  schema={serviceSchema}
  breadcrumbs={[{ name: 'Klíma Telepítés', url: '/szolgaltatasok/klima-telepites' }]}
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4">
      <Breadcrumb items={[{ name: 'Klíma Telepítés', href: '/szolgaltatasok/klima-telepites' }]} />
    </div>
  </div>

  <section class="bg-gradient-to-br from-blue-900 to-blue-800 text-white py-14">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <div class="text-5xl mb-4" aria-hidden="true">{heroIcon}</div>
      <h1 class="text-3xl md:text-4xl font-extrabold mb-4">{heroTitle}</h1>
      <p class="text-lg text-blue-100 mb-6 max-w-2xl mx-auto">{heroSubtitle}</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/ajanlatkeres" class="bg-orange-500 hover:bg-orange-600 text-white px-6 py-3 rounded-xl font-bold transition-colors">Ingyenes Árajánlat</a>
        <a href="tel:+36203394164" class="border-2 border-white/40 hover:border-white text-white px-6 py-3 rounded-xl font-bold hover:bg-white/10 transition-colors">☎ +36 20 339 4164</a>
      </div>
    </div>
  </section>

  <TrustBar />

  <section class="bg-gray-950 py-10">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div class="grid grid-cols-2 gap-3">
          <div class="overflow-hidden rounded-2xl aspect-[3/4]">
            <img src={photo1Src} alt={photo1Alt} class="w-full h-full object-cover" loading="eager" />
          </div>
          <div class="overflow-hidden rounded-2xl aspect-[3/4] mt-6">
            <img src={photo2Src} alt={photo2Alt} class="w-full h-full object-cover" loading="eager" />
          </div>
        </div>
        <div>
          <p class="text-orange-400 font-semibold text-xs uppercase tracking-widest mb-2">{photoLabel}</p>
          <h2 class="text-2xl font-extrabold text-white mb-3">{photoTitle}</h2>
          <p class="text-gray-400 leading-relaxed mb-4">{photoText}</p>
          <a href="/rolunk" class="inline-flex items-center gap-2 text-orange-400 hover:text-orange-300 font-semibold transition-colors text-sm">Ismerje meg a csapatot →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      {bodyHtml ? (
        <div class="prose-klima" set:html={bodyHtml} />
      ) : (
        <div class="prose-klima">
          <h2>Miért Válassza a Klímaépítő.hu Klíma Telepítési Szolgáltatását?</h2>
          <p>A Klímaépítő.hu csapata 10+ év tapasztalattal rendelkezik Budapesten. Minden telepítési munkát precízen, magas minőségű eszközökkel végzünk el, és <strong>2 év garanciát</strong> vállalunk az elvégzett munkára. Kiszállási díjat nem számítunk fel Budapest területén.</p>
          <h2>Milyen Klímarendszereket Szerelünk?</h2>
          <ul>
            <li><strong>Split klíma:</strong> 1 kültéri + 1 beltéri egység – ideális egy szobához vagy kisebb helyiséghez</li>
            <li><strong>Multi-split klíma:</strong> 1 kültéri + 2–5 beltéri egység – több helyiség egyidejű klimatizálása</li>
            <li><strong>Kazettás klíma:</strong> Mennyezetbe süllyesztett, irodai alkalmazáshoz</li>
            <li><strong>Inverteres klíma:</strong> Energiatakarékos, 30–50%-kal alacsonyabb villanyszámla</li>
          </ul>
          <h2>A Telepítés Menete – 5 Lépés</h2>
          <ol>
            <li><strong>Ingyenes helyszíni felmérés:</strong> Kiszállunk, felmérjük a helyiséget és meghatározzuk az optimális teljesítményt</li>
            <li><strong>Árajánlat:</strong> Írásban, tételes bontásban küldjük az ajánlatot</li>
            <li><strong>Időpontegyeztetés:</strong> Rugalmasan alkalmazkodunk az Ön időbeosztásához</li>
            <li><strong>Telepítés:</strong> Precíz munkavégzés, tisztán hagyott munkaterület</li>
            <li><strong>Átadás + Betanítás:</strong> Megmutatjuk a kezelési funkciókat, átadjuk a dokumentációt</li>
          </ol>
          <h2>Forgalmazott Márkák</h2>
          <p>Kizárólag elismert, megbízható gyártók termékeit értékesítjük:</p>
          <ul>
            <li><a href="/keszulekek/fisher-klima"><strong>Fisher klíma</strong></a> – Kiváló ár-érték arány, megbízható minőség</li>
            <li><a href="/keszulekek/fujitsu-klima"><strong>Fujitsu klíma</strong></a> – Japán precizitás, csendes működés, magas hatékonyság</li>
            <li><a href="/keszulekek/toshiba-klima"><strong>Toshiba klíma</strong></a> – Innovatív technológia, prémium kategória</li>
            <li><strong>Daikin klíma</strong> – A világ piacvezetője, kiemelkedő megbízhatóság</li>
          </ul>
        </div>
      )}
    </div>
  </section>

  <section class="py-8 bg-gray-50">
    <div class="container mx-auto px-4 max-w-4xl">
      <PriceTable items={priceItems} title="Klíma Telepítés Árak 2025" />
      <div class="text-center mt-6">
        <a href="/arak" class="text-blue-800 font-semibold hover:text-blue-600 transition-colors">Teljes árlistát megtekintése →</a>
      </div>
    </div>
  </section>

  <FAQ items={faqs} title="Klíma Telepítés – Leggyakoribb Kérdések" />

  <section class="py-12 bg-gray-50">
    <div class="container mx-auto px-4 max-w-xl">
      <QuizForm title="Klíma Telepítés Árajánlat Kérése" />
    </div>
  </section>
</BaseLayout>
