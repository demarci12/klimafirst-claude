---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import TrustBar from '../components/TrustBar.astro';
import { getSite } from '../lib/getSite';
const SITE = await getSite();
import rolunkJson from '../data/rolunk.json';
import { getRolunk } from '../lib/queries';
import { toHTML } from '@portabletext/to-html';

const pageData = (await getRolunk()) ?? rolunkJson;

const heroLabel = pageData.heroLabel ?? 'Ismerjük meg egymást';
const heroTitle = pageData.heroTitle ?? 'Juhász Balázs';
const heroSubtitle = pageData.heroSubtitle ?? 'Sokéves tapasztalat, több száz elvégzett klíma munka Budapesten és környékén. Tulajdonos-vezető, aki már 5+ éve személyesen végzi a munkát.';
const { heroImageSrc, heroImageAlt, profileImageSrc, profileImageAlt, actionPhotos } = pageData;

const stats = pageData.stats ?? [
  { value: '5+', label: 'Év tapasztalat' },
  { value: 'Több száz', label: 'Elvégzett munka' },
  { value: 'Budapest és környéke', label: 'Szolgáltatási terület' },
  { value: 'Akár 10 év', label: 'Garancia' },
];

const filmStripTitle = pageData.filmStripTitle ?? 'Munkában – minden nap Budapesten';
const filmStripSubtitle = pageData.filmStripSubtitle ?? 'Valódi helyszínek, valódi szerelések';

const aboutTitle = pageData.aboutTitle ?? 'A Klímaépítő.hu Csapata';
const aboutBodyHtml = pageData.aboutBody ? toHTML(pageData.aboutBody) : null;

const ownerName = pageData.ownerName ?? 'Juhász Balázs';
const ownerRole = pageData.ownerRole ?? 'Tulajdonos · Főszerelő';
const ownerQuote = pageData.ownerQuote ?? 'Számomra minden egyes ügyfél más és más. Nem sablonos megoldásokat kínálok, hanem az adott ház, az adott igény alapján szabott javaslatot – ez a különbség a Klímaépítő.hu és a többi vállalkozás között.';
const companyName = pageData.companyName ?? 'Juhász Solutions Kft.';
const location = pageData.location ?? 'Budapest';
const typedPhotos = (actionPhotos ?? []) as Array<{ src: string; alt: string }>;
const typedStats = stats as Array<{ value: string; label: string }>;
---

<BaseLayout
  title="Rólunk – Klímaépítő.hu Klímaszerelő Budapest | Juhász Solutions Kft."
  description="Ismerje meg a Klímaépítő.hu csapatát! Juhász Solutions Kft., 5+ év tapasztalat, több száz elvégzett munka Budapest és környékén. Tulajdonos: Juhász Balázs."
  canonical="/rolunk"
  breadcrumbs={[{ name: 'Rólunk', url: '/rolunk' }]}
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4">
      <Breadcrumb items={[{ name: 'Rólunk', href: '/rolunk' }]} />
    </div>
  </div>

  <section class="bg-gradient-to-br from-blue-950 via-blue-900 to-blue-800 text-white overflow-hidden">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[520px]">
        <div class="flex flex-col justify-center py-14 pr-0 lg:pr-12">
          <p class="text-orange-400 font-semibold text-sm uppercase tracking-widest mb-3">{heroLabel}</p>
          <h1 class="text-4xl md:text-5xl font-extrabold leading-tight mb-5">
            {heroTitle}<br/>
            <span class="text-blue-300">Klímaépítő.hu Budapest</span>
          </h1>
          <p class="text-blue-100 text-lg mb-8 leading-relaxed">{heroSubtitle}</p>
          <div class="flex flex-wrap gap-6 mb-8">
            {typedStats.map((s) => (
              <div class="text-center">
                <div class="text-3xl font-extrabold text-orange-400">{s.value}</div>
                <div class="text-blue-200 text-xs uppercase tracking-wide">{s.label}</div>
              </div>
            ))}
          </div>
          <a href="/ajanlatkeres" class="inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-bold px-7 py-3.5 rounded-xl transition-colors shadow-lg w-fit">
            Ingyenes árajánlat
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
        <div class="relative hidden lg:block">
          <img src={heroImageSrc} alt={heroImageAlt} class="absolute inset-0 w-full h-full object-cover object-center" width="600" height="520" loading="eager" />
          <div class="absolute inset-0 bg-gradient-to-r from-blue-950/60 to-transparent"></div>
        </div>
      </div>
    </div>
  </section>

  <TrustBar />

  <section class="py-12 bg-gray-950 overflow-hidden">
    <div class="mb-6 px-6 lg:px-12">
      <h2 class="text-white text-2xl font-bold">{filmStripTitle}</h2>
      <p class="text-gray-400 text-sm mt-1">{filmStripSubtitle}</p>
    </div>
    <div class="flex gap-3 overflow-x-auto pb-4 px-6 lg:px-12 snap-x snap-mandatory scrollbar-hide">
      {typedPhotos.map((photo) => (
        <figure class="flex-none w-52 h-72 overflow-hidden rounded-2xl snap-start">
          <img src={photo.src} alt={photo.alt + ' – Klímaépítő.hu Budapest klímaszerelő'} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" width="208" height="288" loading="lazy" />
        </figure>
      ))}
    </div>
    <p class="text-gray-600 text-xs text-center mt-4">← görgess →</p>
  </section>

  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-bold text-gray-900 mb-5">{aboutTitle}</h2>
          {aboutBodyHtml ? (
            <div class="prose-klima" set:html={aboutBodyHtml} />
          ) : (
            <div class="prose-klima">
              <p>A <strong>Klímaépítő.hu</strong> (Juhász Solutions Kft.) Budapesten tevékenykedő, professzionális klímaszerelési vállalkozás. Alapítója és tulajdonosa <strong>Juhász Balázs</strong>, aki 10+ év iparági tapasztalattal rendelkezik.</p>
              <p>Mottónk: <em>"Elsők a Megoldásban"</em> – ez nem csupán szlogen, hanem minden munkánkat meghatározó elv. Gyorsan reagálunk, pontosan dolgozunk, és minden esetben az ügyfél érdekeit tartjuk szem előtt.</p>
              <h3>Szakterületeink</h3>
              <ul>
                <li>Split és multi-split klímarendszerek telepítése</li>
                <li>Fisher, Fujitsu, Toshiba, Daikin, Gree készülékek</li>
                <li>Klímarendszerek javítása és karbantartása</li>
                <li>Hőszivattyús fűtési rendszerek tervezése és kivitelezése</li>
              </ul>
              <h3>Miért Vagyunk Mások?</h3>
              <ul>
                <li><strong>Ingyenes helyszíni felmérés</strong> – kiszállási díj nélkül</li>
                <li><strong>Személyre szabott árak</strong> – nem sablonos ajánlatok</li>
                <li><strong>Precíz munkavégzés</strong> – minőségi eszközök, tiszta munkaterület</li>
                <li><strong>Gyors kiszállás</strong> – 1–3 napon belül Budapesten és a környéken</li>
                <li><strong>2 év garancia</strong> – minden elvégzett munkára</li>
              </ul>
              <p class="mt-4 text-sm text-gray-600"><strong>Fontos:</strong> Hőszivattyú telepítését nem vállaljuk, kizárólag klímafűtési megoldásokat kínálunk.</p>
            </div>
          )}
        </div>

        <div class="lg:col-span-2 space-y-5">
          <div class="rounded-3xl overflow-hidden shadow-xl border border-gray-100">
            <div class="relative h-64">
              <img src={profileImageSrc} alt={profileImageAlt} class="w-full h-full object-cover object-top" width="400" height="256" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-blue-950/80 to-transparent"></div>
              <div class="absolute bottom-4 left-4 right-4">
                <div class="font-bold text-white text-xl">{ownerName}</div>
                <div class="text-orange-300 text-sm font-medium">{ownerRole}</div>
              </div>
            </div>
            <div class="bg-blue-50 p-5">
              <blockquote class="text-gray-700 text-sm italic leading-relaxed border-l-4 border-orange-400 pl-4">
                "{ownerQuote}"
              </blockquote>
            </div>
          </div>

          <div class="bg-white border border-gray-200 rounded-2xl p-5 shadow-sm text-sm space-y-3">
            <div class="flex justify-between">
              <span class="text-gray-500">Cég neve</span>
              <span class="font-medium text-gray-900">{companyName}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Telephely</span>
              <span class="font-medium text-gray-900">{location}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Telefon</span>
              <a href={`tel:${SITE.phoneTel}`} class="font-medium text-orange-600 hover:text-orange-500">{SITE.phone}</a>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">E-mail</span>
              <a href={`mailto:${SITE.email}`} class="font-medium text-blue-700 hover:text-blue-500">{SITE.email}</a>
            </div>
          </div>

          <a href="/ajanlatkeres" class="block bg-orange-500 hover:bg-orange-600 text-white px-6 py-4 rounded-2xl font-bold text-center transition-colors shadow-md">
            Ingyenes Árajánlat Kérése
          </a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  </style>
</BaseLayout>
