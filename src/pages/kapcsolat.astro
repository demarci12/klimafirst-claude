---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE } from '../data/site';
---

<BaseLayout
  title="Kapcsolat – KlimaFirst Klímaszerelő Budapest | +36 20 339 4164"
  description="Lépjen kapcsolatba a KlimaFirst klímaszerelő csapatával Budapesten. ☎ +36 20 339 4164 | ✉ info@klimafirst.hu | Ingyenes helyszíni felmérés."
  canonical="/kapcsolat"
  breadcrumbs={[{ name: 'Kapcsolat', url: '/kapcsolat' }]}
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4">
      <Breadcrumb items={[{ name: 'Kapcsolat', href: '/kapcsolat' }]} />
    </div>
  </div>

  <section class="py-12 bg-white">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-10">
        <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-3">Kapcsolat – KlimaFirst Budapest</h1>
        <p class="text-gray-600 max-w-xl mx-auto">Kérdése van? Hívjon minket közvetlenül, vagy töltse ki az alábbi kapcsolatfelvételi űrlapot.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <!-- Contact info -->
        <div>
          <h2 class="text-xl font-bold text-gray-900 mb-6">Elérhetőségeink</h2>

          <div class="space-y-5">
            <div class="flex items-start gap-4 p-4 bg-gray-50 rounded-2xl">
              <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-900 mb-1">Telefon</div>
                <a href="tel:+36203394164" class="text-orange-600 font-bold text-lg hover:text-orange-500 transition-colors">
                  +36 20 339 4164
                </a>
                <p class="text-xs text-gray-500 mt-1">Hétfő–Péntek: 8:00–18:00, Szombat: 9:00–14:00</p>
              </div>
            </div>

            <div class="flex items-start gap-4 p-4 bg-gray-50 rounded-2xl">
              <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-900 mb-1">E-mail</div>
                <a href="mailto:info@klimafirst.hu" class="text-blue-700 hover:text-blue-500 transition-colors">
                  info@klimafirst.hu
                </a>
                <p class="text-xs text-gray-500 mt-1">24 órán belül válaszolunk</p>
              </div>
            </div>

            <div class="flex items-start gap-4 p-4 bg-gray-50 rounded-2xl">
              <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-gray-900 mb-1">Területi lefedettség</div>
                <p class="text-gray-700 text-sm">Budapest mind a 23 kerülete</p>
                <p class="text-gray-500 text-xs mt-0.5">+ Budapest–Siófok korridor</p>
              </div>
            </div>

            <div class="p-4 bg-blue-50 rounded-2xl border border-blue-200">
              <div class="font-semibold text-blue-900 mb-2">Ingyenes helyszíni felmérés</div>
              <p class="text-sm text-blue-700">Kiszállási díj nélkül érkezünk, megvizsgáljuk a helyszínt és kötelezettségmentes árajánlatot adunk. Budapest egész területén.</p>
            </div>
          </div>
        </div>

        <!-- Form -->
        <div>
          <ContactForm title="Üzenet Küldése" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
