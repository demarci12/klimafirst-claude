---

<BaseLayout
  title="Referenciák – KlimaFirst Klímaszerelő Budapest | 5000+ Elvégzett Munka"
  description="5000+ elvégzett referencia Budapesten. Valódi fotók elvégzett klímaszerelési munkáinkról. Telepítés, javítás, karbantartás Budapest mind a 23 kerületében."
  canonical="/referenciak"
  breadcrumbs={[{ name: 'Referenciák', url: '/referenciak' }]}
>
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4">
      <Breadcrumb items={[{ name: 'Referenciák', href: '/referenciak' }]} />
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-blue-950 via-blue-900 to-blue-800 text-white py-16">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <p class="text-orange-400 font-semibold text-sm uppercase tracking-widest mb-3">Elvégzett munkáink</p>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">5000+ Referencia<br/><span class="text-blue-300">Budapest-szerte</span></h1>
      <p class="text-blue-100 text-lg max-w-2xl mx-auto">
        Valódi fotók, valódi ügyfelek – klíma telepítés, szerviz és karbantartás Budapest mind a 23 kerületéből.
      </p>
    </div>
  </section>

  <TrustBar />

  <!-- Testimonials -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 max-w-5xl">
      <h2 class="text-2xl font-bold text-gray-900 text-center mb-2">Mit mondanak ügyfeleink?</h2>
      <p class="text-gray-500 text-center mb-10">Valódi vélemények valódi emberektől</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {testimonials.map((t) => (
          <article class="bg-gray-50 rounded-2xl border border-gray-200 p-5 flex flex-col gap-3">
            <div class="flex gap-0.5" aria-label={`${t.rating} / 5 csillag`}>
              {Array.from({ length: t.rating }).map(() => (
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="text-gray-700 text-sm italic leading-relaxed flex-1">"{t.text}"</blockquote>
            <div class="flex items-center gap-3 pt-2 border-t border-gray-200">
              <div class="w-9 h-9 bg-blue-900 rounded-full flex items-center justify-center text-white text-sm font-bold flex-shrink-0">
                {t.name.charAt(0)}
              </div>
              <div>
                <div class="font-semibold text-gray-900 text-sm">{t.name}</div>
                <div class="text-xs text-gray-500">{t.location}</div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Photo wall -->
  <section class="py-14 bg-gray-950">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-extrabold text-white mb-2">Munkafotók</h2>
        <p class="text-gray-400">Kattintson a képre a nagyításhoz</p>
      </div>

      <!-- Masonry via CSS columns -->
      <div class="columns-2 sm:columns-3 lg:columns-4 gap-3 space-y-3">
        {refPhotos.map((filename, i) => (
          <figure
            class="break-inside-avoid overflow-hidden rounded-xl cursor-pointer group relative"
            onclick={`openLightbox('/images/referenciak/${filename}')`}
          >
            <img
              src={`/images/referenciak/${filename}`}
              alt={`KlimaFirst klíma telepítési referencia Budapest – elvégzett munka ${i + 1}`}
              class="w-full block group-hover:scale-105 transition-transform duration-500 group-hover:brightness-90"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="bg-black/50 rounded-full p-3">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/>
                </svg>
              </div>
            </div>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-14 bg-white text-center">
    <p class="text-gray-600 mb-2 text-lg">Szeretne Ön is elégedett ügyfeleink közé tartozni?</p>
    <p class="text-gray-400 text-sm mb-6">Ingyenes helyszíni felmérés, kiszállási díj nélkül</p>
    <a href="/ajanlatkeres" class="bg-orange-500 hover:bg-orange-600 text-white px-10 py-4 rounded-xl font-bold inline-block transition-colors shadow-lg text-lg">
      Ingyenes Árajánlat Kérése
    </a>
  </section>

  <!-- Lightbox -->
  <dialog id="lightbox" class="fixed inset-0 w-full h-full bg-black/90 flex items-center justify-center p-4 z-50 max-w-none max-h-none m-0">
    <button onclick="closeLightbox()" class="absolute top-4 right-4 text-white bg-white/10 hover:bg-white/20 rounded-full p-2 transition-colors" aria-label="Bezárás">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <img id="lightbox-img" src="" alt="Referencia nagyítva" class="max-w-full max-h-[90vh] object-contain rounded-xl shadow-2xl" />
  </dialog>

  <script>
    function openLightbox(src: string) {
      const dialog = document.getElementById('lightbox') as HTMLDialogElement;
      const img = document.getElementById('lightbox-img') as HTMLImageElement;
      img.src = src;
      dialog.showModal();
    }
    function closeLightbox() {
      const dialog = document.getElementById('lightbox') as HTMLDialogElement;
      dialog.close();
    }
    document.getElementById('lightbox')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) closeLightbox();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeLightbox();
    });
  </script>

  <style>
    dialog::backdrop { background: rgba(0,0,0,0.85); }
    dialog[open] { display: flex; align-items: center; justify-content: center; }
  </style>
</BaseLayout>
