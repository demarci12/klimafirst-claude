# ─── TinaCloud credentials ─────────────────────────────────────────────────────
# Required for: npm run build (generates /admin UI) and production content editing
#
# Steps to get these:
#   1. Sign up free at https://app.tina.io
#   2. Create a new project → connect your GitHub repo (demarci12/klimafirst-claude)
#   3. Copy the Client ID and a read/write Token into this file
#
TINA_CLIENT_ID=
TINA_TOKEN=

# Git branch TinaCMS should target (auto-detected in Vercel/Netlify)
# GITHUB_BRANCH=main
